{
  "name": "gens-launcher",
  "version": "1.5.8",
  "description": "Lanceur Minecraft moderne et rapide.",
  "main": "main.js",
  "author": "William Bossard <wbossard@free.fr>",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "dist:all": "electron-builder --win --linux"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.8.3",
    "minecraft-launcher-core": "^3.18.2",
    "prismarine-auth": "^3.1.1",
    "prismarine-nbt": "^2.2.1"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.gens.launcher",
    "productName": "Gens Launcher",
    "electronVersion": "31.0.0",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "WilliamBossard",
        "repo": "Gens-Launcher"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "uninstallDisplayName": "Désinstaller Gens Launcher"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Game",
      "icon": "assets/icon.png",
      "artifactName": "GensLauncher-${version}-${arch}.${ext}",
      "executableArgs": [
        "--no-sandbox",
        "--disable-setuid-sandbox"
      ],
      "desktop": {
        "entry": {
          "Name": "Gens Launcher",
          "Icon": "gens-launcher"
        }
      }
    },
    "deb": {
      "priority": "optional",
      "maintainer": "William Bossard <wbossard@free.fr>"
    }
  }
}