{
  "name": "gens-launcher",
  "version": "1.5.0",
  "description": "Lanceur Minecraft open-source moderne et léger.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "author": "Gens",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.10",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.8.3",
    "minecraft-launcher-core": "^3.18.2",
    "prismarine-auth": "^3.1.1",
    "prismarine-nbt": "^2.2.1"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1"
  },
  "overrides": {
    "tough-cookie": "^4.1.3",
    "qs": "^6.14.1"
  },
  "build": {
    "appId": "com.gens.launcher",
    "productName": "Gens Launcher",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "WilliamBossard",
        "repo": "Gens-Launcher"
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "GensLauncher-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}