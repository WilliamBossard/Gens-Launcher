{
  "name": "gens-launcher",
  "version": "1.4.7",
  "description": "Lanceur Minecraft open-source moderne et léger.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "author": "Gens",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.10",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.8.3",
    "minecraft-launcher-core": "^3.18.2",
    "prismarine-auth": "^2.7.0",
    "prismarine-nbt": "^2.2.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
"build": {
    "appId": "com.gens.launcher",
    "productName": "Gens Launcher",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "WilliamBossard",
        "repo": "Gens-Launcher"
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "GensLauncher-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "assets/icon.png",
      "category": "Game",
      "artifactName": "GensLauncher-${version}-Linux.${ext}"
    }
  }
}
