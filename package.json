{
  "name": "gens-launcher",
  "version": "1.1.1",
  "description": "Gens Launcher",
  "main": "main.js",
  "author": "William Bossard",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.gens.launcher",
    "productName": "Gens Launcher",
    "artifactName": "GensLauncher-Setup-${version}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "WilliamBossard",
        "repo": "Gens-Launcher"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/vanilla.png",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    },
    "files": [
      "**/*",
      "!instances/*",
      "!accounts.json",
      "!instances.json",
      "!dist/*"
    ]
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.1.4",
    "minecraft-launcher-core": "latest",
    "msmc": "^5.0.5"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  }
}
